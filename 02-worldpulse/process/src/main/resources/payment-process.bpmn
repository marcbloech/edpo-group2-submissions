<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_Payment" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <bpmn:error id="Error_PaymentProcessing" name="PaymentProcessingError" errorCode="PAYMENT_ERROR" />
  <bpmn:process id="payment-process" name="WorldPulse Payment Process" isExecutable="true">
    <bpmn:startEvent id="StartEvent_PaymentFlow" name="Payment Flow Started">
      <bpmn:outgoing>Flow_to_ProcessPayment</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_ProcessPayment" name="Process Payment">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="process-payment" />
        <zeebe:ioMapping>
          <zeebe:input source="=userId" target="userId" />
          <zeebe:input source="=tier" target="tier" />
          <zeebe:input source="=traceid" target="traceid" />
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="=name" target="name" />
          <zeebe:input source="=if forcePaymentFailure = null then false else forcePaymentFailure" target="forcePaymentFailure" />
          <zeebe:input source="=if forcePaymentError = null then false else forcePaymentError" target="forcePaymentError" />
          <zeebe:input source="=if retryCount = null then 1 else retryCount + 1" target="retryCount" />
          <zeebe:input source="=if maxRetryCount = null then 3 else maxRetryCount" target="maxRetryCount" />
          <zeebe:output source="=paymentSuccess" target="paymentSuccess" />
          <zeebe:output source="=paymentAmount" target="paymentAmount" />
          <zeebe:output source="=transactionId" target="transactionId" />
          <zeebe:output source="=retryCount" target="retryCount" />
          <zeebe:output source="=maxRetryCount" target="maxRetryCount" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_ProcessPayment</bpmn:incoming>
      <bpmn:incoming>Flow_RetryPayment</bpmn:incoming>
      <bpmn:outgoing>Flow_to_PaymentGateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="BoundaryEvent_PaymentTimeout" name="Payment Timeout (5 min)" attachedToRef="Task_ProcessPayment">
      <bpmn:outgoing>Flow_PaymentTimeout_to_Error</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT5M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_PaymentError" name="Payment Processing Error" attachedToRef="Task_ProcessPayment">
      <bpmn:outgoing>Flow_PaymentError_to_Notification</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_PaymentProcessing" />
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="Gateway_PaymentResult" name="Payment Successful?">
      <bpmn:incoming>Flow_to_PaymentGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_PaymentSuccess</bpmn:outgoing>
      <bpmn:outgoing>Flow_PaymentFailed</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_NotifyPaymentSuccess" name="Send Payment Success Notification">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" />
        <zeebe:ioMapping>
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="=name" target="name" />
          <zeebe:input source="=tier" target="tier" />
          <zeebe:input source="=traceid" target="traceid" />
          <zeebe:input source="=paymentAmount" target="paymentAmount" />
          <zeebe:input source="=transactionId" target="transactionId" />
          <zeebe:input source="= &#34;PaymentReceivedEvent&#34;" target="notificationType" />
          <zeebe:output source="=notificationSent" target="notificationSent" />
          <zeebe:output source="=notificationId" target="notificationId" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PaymentSuccess</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifySuccess_to_Slack</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:serviceTask id="Task_SlackPaymentSuccess" name="Slack: Payment Success">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:slack:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="{{secrets.SLACK_OAUTH_TOKEN}}" target="token" />
          <zeebe:input source="= &#34;chat.postMessage&#34;" target="method" />
          <zeebe:input source="= &#34;plainText&#34;" target="data.messageType" />
          <zeebe:input source="= &#34;✅ *Payment succeeded*\nTrace ID: &#34; + traceid + &#34;\nEmail: &#34; + email + &#34;\nName: &#34; + name + &#34;\nTier: &#34; + tier + &#34;\nAmount: &#34; + string(paymentAmount) + &#34;\nTransaction: &#34; + transactionId" target="data.text" />
          <zeebe:input source="{{secrets.SLACK_CHANNEL}}" target="data.channel" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NotifySuccess_to_Slack</bpmn:incoming>
      <bpmn:outgoing>Flow_to_EndSuccess</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_RetryDecision" name="Decide: Retry Payment?">
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="retryPaymentForm" bindingType="deployment" />
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PaymentFailed</bpmn:incoming>
      <bpmn:outgoing>Flow_to_RetryGateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_RetryDecision" name="Retry?">
      <bpmn:incoming>Flow_to_RetryGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_RetryPayment</bpmn:outgoing>
      <bpmn:outgoing>Flow_CancelSignup</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Task_NotifyPaymentFailed" name="Send Payment Failed Notification">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" />
        <zeebe:ioMapping>
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="=name" target="name" />
          <zeebe:input source="=tier" target="tier" />
          <zeebe:input source="=traceid" target="traceid" />
          <zeebe:input source="=paymentAmount" target="paymentAmount" />
          <zeebe:input source="= &#34;PaymentFailedEvent&#34;" target="notificationType" />
          <zeebe:output source="=notificationSent" target="notificationSent" />
          <zeebe:output source="=notificationId" target="notificationId" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CancelSignup</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyFailed_to_Slack</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:serviceTask id="Task_SlackPaymentFailed" name="Slack: Payment Failed">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:slack:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="{{secrets.SLACK_OAUTH_TOKEN}}" target="token" />
          <zeebe:input source="= &#34;chat.postMessage&#34;" target="method" />
          <zeebe:input source="= &#34;plainText&#34;" target="data.messageType" />
          <zeebe:input source="= &#34;⚠️ *Payment failed (signup cancelled)*\nTrace ID: &#34; + traceid + &#34;\nEmail: &#34; + email + &#34;\nName: &#34; + name + &#34;\nTier: &#34; + tier + &#34;\nAmount: &#34; + string(paymentAmount) + &#34;\nNotification: PaymentFailedEvent&#34;" target="data.text" />
          <zeebe:input source="{{secrets.SLACK_CHANNEL}}" target="data.channel" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NotifyFailed_to_Slack</bpmn:incoming>
      <bpmn:outgoing>Flow_to_EndFailed</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Task_NotifyError" name="Send Error Notification">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" />
        <zeebe:ioMapping>
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="=name" target="name" />
          <zeebe:input source="=tier" target="tier" />
          <zeebe:input source="=traceid" target="traceid" />
          <zeebe:input source="= &#34;TechnicalError&#34;" target="notificationType" />
          <zeebe:output source="=notificationSent" target="notificationSent" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PaymentError_to_Notification</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyError_to_Slack</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:serviceTask id="Task_SlackPaymentError" name="Slack: Payment Processing Error">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:slack:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="{{secrets.SLACK_OAUTH_TOKEN}}" target="token" />
          <zeebe:input source="= &#34;chat.postMessage&#34;" target="method" />
          <zeebe:input source="= &#34;plainText&#34;" target="data.messageType" />
          <zeebe:input source="= &#34;🚨 *Payment process error*\nTrace ID: &#34; + traceid + &#34;\nUser ID: &#34; + userId + &#34;\nEmail: &#34; + email + &#34;\nName: &#34; + name + &#34;\nTier: &#34; + tier + &#34;\nPayment amount: &#34; + string(if paymentAmount != null then paymentAmount else 0) + &#34;\nContext: payment-processing error (boundary)&#34;" target="data.text" />
          <zeebe:input source="{{secrets.SLACK_CHANNEL}}" target="data.channel" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NotifyError_to_Slack</bpmn:incoming>
      <bpmn:outgoing>Flow_PaymentError_to_Error</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_PaymentSuccess" name="Payment Flow Completed">
      <bpmn:incoming>Flow_to_EndSuccess</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_PaymentFailed" name="Signup Failed (Payment)">
      <bpmn:incoming>Flow_to_EndFailed</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_TechnicalError" name="Technical Error">
      <bpmn:incoming>Flow_PaymentTimeout_to_Error</bpmn:incoming>
      <bpmn:incoming>Flow_PaymentError_to_Error</bpmn:incoming>
      <bpmn:errorEventDefinition errorRef="Error_PaymentProcessing" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_to_ProcessPayment" sourceRef="StartEvent_PaymentFlow" targetRef="Task_ProcessPayment" />
    <bpmn:sequenceFlow id="Flow_to_PaymentGateway" sourceRef="Task_ProcessPayment" targetRef="Gateway_PaymentResult" />
    <bpmn:sequenceFlow id="Flow_PaymentSuccess" name="Yes" sourceRef="Gateway_PaymentResult" targetRef="Task_NotifyPaymentSuccess">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= paymentSuccess = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_PaymentFailed" name="No" sourceRef="Gateway_PaymentResult" targetRef="Task_RetryDecision">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= paymentSuccess = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_to_RetryGateway" sourceRef="Task_RetryDecision" targetRef="Gateway_RetryDecision" />
    <bpmn:sequenceFlow id="Flow_RetryPayment" name="Yes" sourceRef="Gateway_RetryDecision" targetRef="Task_ProcessPayment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= retryPayment = true and retryCount &lt; maxRetryCount</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_CancelSignup" name="No" sourceRef="Gateway_RetryDecision" targetRef="Task_NotifyPaymentFailed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= retryPayment = false or retryCount &gt;= maxRetryCount</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NotifySuccess_to_Slack" sourceRef="Task_NotifyPaymentSuccess" targetRef="Task_SlackPaymentSuccess" />
    <bpmn:sequenceFlow id="Flow_to_EndSuccess" sourceRef="Task_SlackPaymentSuccess" targetRef="EndEvent_PaymentSuccess" />
    <bpmn:sequenceFlow id="Flow_NotifyFailed_to_Slack" sourceRef="Task_NotifyPaymentFailed" targetRef="Task_SlackPaymentFailed" />
    <bpmn:sequenceFlow id="Flow_to_EndFailed" sourceRef="Task_SlackPaymentFailed" targetRef="EndEvent_PaymentFailed" />
    <bpmn:sequenceFlow id="Flow_PaymentTimeout_to_Error" sourceRef="BoundaryEvent_PaymentTimeout" targetRef="EndEvent_TechnicalError" />
    <bpmn:sequenceFlow id="Flow_PaymentError_to_Notification" sourceRef="BoundaryEvent_PaymentError" targetRef="Task_NotifyError" />
    <bpmn:sequenceFlow id="Flow_NotifyError_to_Slack" sourceRef="Task_NotifyError" targetRef="Task_SlackPaymentError" />
    <bpmn:sequenceFlow id="Flow_PaymentError_to_Error" sourceRef="Task_SlackPaymentError" targetRef="EndEvent_TechnicalError" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Payment">
    <bpmndi:BPMNPlane id="BPMNPlane_Payment" bpmnElement="payment-process">
      <bpmndi:BPMNShape id="StartEvent_PaymentFlow_di" bpmnElement="StartEvent_PaymentFlow">
        <dc:Bounds x="170" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="153" y="258" width="70" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProcessPayment_di" bpmnElement="Task_ProcessPayment">
        <dc:Bounds x="260" y="200" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PaymentResult_di" bpmnElement="Gateway_PaymentResult" isMarkerVisible="true">
        <dc:Bounds x="450" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="445" y="177.5" width="60" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyPaymentSuccess_di" bpmnElement="Task_NotifyPaymentSuccess">
        <dc:Bounds x="650" y="200" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RetryDecision_di" bpmnElement="Task_RetryDecision">
        <dc:Bounds x="520" y="320" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_RetryDecision_di" bpmnElement="Gateway_RetryDecision" isMarkerVisible="true">
        <dc:Bounds x="725" y="335" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="733" y="311" width="33" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyPaymentFailed_di" bpmnElement="Task_NotifyPaymentFailed">
        <dc:Bounds x="665" y="470" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyError_di" bpmnElement="Task_NotifyError">
        <dc:Bounds x="300" y="600" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SlackPaymentError_di" bpmnElement="Task_SlackPaymentError">
        <dc:Bounds x="460" y="600" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_TechnicalError_di" bpmnElement="EndEvent_TechnicalError">
        <dc:Bounds x="712" y="622" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="693" y="598" width="74" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_PaymentFailed_di" bpmnElement="EndEvent_PaymentFailed">
        <dc:Bounds x="1042" y="492" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1026" y="455" width="68" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SlackPaymentFailed_di" bpmnElement="Task_SlackPaymentFailed">
        <dc:Bounds x="890" y="470" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_PaymentSuccess_di" bpmnElement="EndEvent_PaymentSuccess">
        <dc:Bounds x="1042" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1025" y="258" width="70" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SlackPaymentSuccess_di" bpmnElement="Task_SlackPaymentSuccess">
        <dc:Bounds x="890" y="200" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BoundaryEvent_PaymentError_di" bpmnElement="BoundaryEvent_PaymentError">
        <dc:Bounds x="352" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="329" y="298" width="83" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BoundaryEvent_PaymentTimeout_di" bpmnElement="BoundaryEvent_PaymentTimeout">
        <dc:Bounds x="272" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="247" y="298" width="86" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_to_ProcessPayment_di" bpmnElement="Flow_to_ProcessPayment">
        <di:waypoint x="206" y="240" />
        <di:waypoint x="260" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_PaymentGateway_di" bpmnElement="Flow_to_PaymentGateway">
        <di:waypoint x="390" y="240" />
        <di:waypoint x="450" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PaymentSuccess_di" bpmnElement="Flow_PaymentSuccess">
        <di:waypoint x="500" y="240" />
        <di:waypoint x="650" y="240" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="566" y="215" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PaymentFailed_di" bpmnElement="Flow_PaymentFailed">
        <di:waypoint x="475" y="265" />
        <di:waypoint x="475" y="360" />
        <di:waypoint x="520" y="360" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="483" y="303" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_RetryGateway_di" bpmnElement="Flow_to_RetryGateway">
        <di:waypoint x="680" y="360" />
        <di:waypoint x="725" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RetryPayment_di" bpmnElement="Flow_RetryPayment">
        <di:waypoint x="775" y="360" />
        <di:waypoint x="850" y="360" />
        <di:waypoint x="850" y="150" />
        <di:waypoint x="325" y="150" />
        <di:waypoint x="325" y="200" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="579" y="125" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_CancelSignup_di" bpmnElement="Flow_CancelSignup">
        <di:waypoint x="750" y="385" />
        <di:waypoint x="750" y="470" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="738" y="393" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NotifySuccess_to_Slack_di" bpmnElement="Flow_NotifySuccess_to_Slack">
        <di:waypoint x="810" y="240" />
        <di:waypoint x="890" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_EndSuccess_di" bpmnElement="Flow_to_EndSuccess">
        <di:waypoint x="1010" y="240" />
        <di:waypoint x="1042" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NotifyFailed_to_Slack_di" bpmnElement="Flow_NotifyFailed_to_Slack">
        <di:waypoint x="835" y="510" />
        <di:waypoint x="890" y="510" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_EndFailed_di" bpmnElement="Flow_to_EndFailed">
        <di:waypoint x="1010" y="510" />
        <di:waypoint x="1042" y="510" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PaymentTimeout_to_Error_di" bpmnElement="Flow_PaymentTimeout_to_Error">
        <di:waypoint x="290" y="298" />
        <di:waypoint x="290" y="710" />
        <di:waypoint x="730" y="710" />
        <di:waypoint x="730" y="658" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PaymentError_to_Notification_di" bpmnElement="Flow_PaymentError_to_Notification">
        <di:waypoint x="370" y="298" />
        <di:waypoint x="370" y="600" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NotifyError_to_Slack_di" bpmnElement="Flow_NotifyError_to_Slack">
        <di:waypoint x="440" y="640" />
        <di:waypoint x="460" y="640" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PaymentError_to_Error_di" bpmnElement="Flow_PaymentError_to_Error">
        <di:waypoint x="580" y="640" />
        <di:waypoint x="712" y="640" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
