<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.20.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.4.0">
  
  <!-- ERROR DEFINITIONS -->
  <bpmn:error id="Error_PaymentProcessing" name="PaymentProcessingError" errorCode="PAYMENT_ERROR" />
  <bpmn:error id="Error_AccountActivation" name="AccountActivationError" errorCode="ACTIVATION_ERROR" />
  
  <bpmn:process id="signup-payment-process" name="WorldPulse Signup and Payment Process" isExecutable="true">
    
    <!-- START EVENT -->
    <bpmn:startEvent id="StartEvent_SignupRequest" name="Signup Request Received">
      <bpmn:documentation>
        User initiates signup with name, email, and tier selection.
        Required variables: name, email, tier
      </bpmn:documentation>
      <bpmn:outgoing>Flow_to_ValidateSignup</bpmn:outgoing>
    </bpmn:startEvent>
    
    <!-- SERVICE TASK: Validate Signup Data -->
    <bpmn:serviceTask id="Task_ValidateSignup" name="Validate Signup Data">
      <bpmn:documentation>
        Validates signup data and generates unique userId.
        
        Input: name, email, tier
        Output: userId (UUID), traceid, source
        
        Business Logic:
        - Generate unique userId (UUID format)
        - Validate email format (RFC 5322)
        - Check for duplicate email in database
        - Sanitize input data
        - Set CloudEvents metadata (source, time, id)
      </bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="validate-signup" />
        <zeebe:ioMapping>
          <zeebe:input source="=name" target="name" />
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="=tier" target="tier" />
          <zeebe:output source="=userId" target="userId" />
          <zeebe:output source="=traceid" target="traceid" />
          <zeebe:output source="=source" target="source" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="eventType" value="SignupRequestedEvent" />
          <zeebe:header key="kafkaTopic" value="worldpulse" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_ValidateSignup</bpmn:incoming>
      <bpmn:outgoing>Flow_to_InitialNotification</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- SERVICE TASK: Send Initial Processing Notification (Exercise 2 Compatible) -->
    <bpmn:serviceTask id="Task_SendInitialNotification" name="Send Initial Processing Notification">
      <bpmn:documentation>
        Sends initial "signup is being processed" notification to ALL users (FREE, PRO, ENTERPRISE).
        This matches Exercise 2's NotificationService.notifySignup() behavior.
        
        Input: email, name, tier, traceid
        Output: notificationSent (boolean), notificationId
        
        Email Template:
        Subject: Welcome to WorldPulse!
        Body:
          Dear {name},
          Your {tier} signup is being processed.
          We'll notify you once everything is ready.
          Trace: {traceid}
      </bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" />
        <zeebe:ioMapping>
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="=name" target="name" />
          <zeebe:input source="=tier" target="tier" />
          <zeebe:input source="=traceid" target="traceid" />
          <zeebe:input source="&quot;SignupRequestedEvent&quot;" target="notificationType" />
          <zeebe:output source="=notificationSent" target="notificationSent" />
          <zeebe:output source="=notificationId" target="notificationId" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="eventType" value="SignupRequestedEvent" />
          <zeebe:header key="emailSubject" value="Welcome to WorldPulse!" />
          <zeebe:header key="allTiers" value="true" />
          <zeebe:header key="kafkaTopic" value="worldpulse" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_InitialNotification</bpmn:incoming>
      <bpmn:outgoing>Flow_to_CheckTier</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- EXCLUSIVE GATEWAY: Check if payment required -->
    <bpmn:exclusiveGateway id="Gateway_CheckTier" name="Payment Required?">
      <bpmn:documentation>
        Decision point: Determines if payment processing is required based on subscription tier.
        
        Conditions:
        - FREE tier → No payment required, proceed to welcome notification
        - PRO or ENTERPRISE tier → Payment required, proceed to payment processing
        
        This gateway implements the business rule that separates free from paid users.
      </bpmn:documentation>
      <bpmn:incoming>Flow_to_CheckTier</bpmn:incoming>
      <bpmn:outgoing>Flow_PaymentRequired</bpmn:outgoing>
      <bpmn:outgoing>Flow_FreeTier</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <!-- SERVICE TASK: Process Payment -->
    <bpmn:serviceTask id="Task_ProcessPayment" name="Process Payment">
      <bpmn:documentation>
        Processes payment based on selected tier.
        
        Input: userId, tier, traceid, email, name
        Output: paymentSuccess (boolean), paymentAmount (integer), transactionId
        
        Pricing:
        - FREE: 0 cents (no payment)
        - PRO: 1900 cents (CHF 19.00)
        - ENTERPRISE: 9900 cents (CHF 99.00)
        
        Business Logic:
        - Calculate amount based on tier
        - Call payment provider API (Stripe/PayPal simulation)
        - Simulate 80% success rate for paid tiers
        - Return payment status and transaction details
        - Publish PaymentReceivedEvent or PaymentFailedEvent to Kafka
      </bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="process-payment" />
        <zeebe:ioMapping>
          <zeebe:input source="=userId" target="userId" />
          <zeebe:input source="=tier" target="tier" />
          <zeebe:input source="=traceid" target="traceid" />
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="=name" target="name" />
          <zeebe:output source="=paymentSuccess" target="paymentSuccess" />
          <zeebe:output source="=paymentAmount" target="paymentAmount" />
          <zeebe:output source="=transactionId" target="transactionId" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="pricingPRO" value="1900" />
          <zeebe:header key="pricingENTERPRISE" value="9900" />
          <zeebe:header key="pricingFREE" value="0" />
          <zeebe:header key="successRate" value="0.8" />
          <zeebe:header key="eventTypeSuccess" value="PaymentReceivedEvent" />
          <zeebe:header key="eventTypeFailure" value="PaymentFailedEvent" />
          <zeebe:header key="kafkaTopic" value="worldpulse" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PaymentRequired</bpmn:incoming>
      <bpmn:incoming>Flow_RetryPayment</bpmn:incoming>
      <bpmn:outgoing>Flow_to_PaymentGateway</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- BOUNDARY TIMER EVENT on Process Payment (5 minute timeout) -->
    <bpmn:boundaryEvent id="BoundaryEvent_PaymentTimeout" name="Payment Timeout (5 min)" attachedToRef="Task_ProcessPayment">
      <bpmn:documentation>
        Triggers if payment processing takes longer than 5 minutes.
        This prevents the process from hanging indefinitely.
      </bpmn:documentation>
      <bpmn:outgoing>Flow_PaymentTimeout_to_Error</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT5M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    
    <!-- BOUNDARY ERROR EVENT on Process Payment -->
    <bpmn:boundaryEvent id="BoundaryEvent_PaymentError" name="Payment Processing Error" attachedToRef="Task_ProcessPayment">
      <bpmn:documentation>
        Catches technical errors during payment processing (API failures, network errors, etc).
      </bpmn:documentation>
      <bpmn:outgoing>Flow_PaymentError_to_Notification</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_PaymentProcessing" />
    </bpmn:boundaryEvent>
    
    <!-- EXCLUSIVE GATEWAY: Payment Success? -->
    <bpmn:exclusiveGateway id="Gateway_PaymentResult" name="Payment Successful?">
      <bpmn:documentation>
        Decision point: Routes based on payment processing outcome.
        
        Conditions:
        - Payment succeeded → Send success notification, activate account
        - Payment failed → Send failure notification, end process
        
        Success rate: ~80% for simulated payments
        Failure scenarios: Insufficient funds, card declined, network errors
      </bpmn:documentation>
      <bpmn:incoming>Flow_to_PaymentGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_PaymentSuccess</bpmn:outgoing>
      <bpmn:outgoing>Flow_PaymentFailed</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <!-- SERVICE TASK: Send Payment Success Notification -->
    <bpmn:serviceTask id="Task_NotifyPaymentSuccess" name="Send Payment Success Notification">
      <bpmn:documentation>
        Sends payment confirmation email to user.
        
        Input: email, name, tier, traceid, paymentAmount, transactionId
        Output: notificationSent (boolean), notificationId
        
        Email Template:
        Subject: Payment Confirmed - Welcome to WorldPulse {tier}!
        Body: 
          Dear {name},
          Your payment of CHF {amount} has been received.
          Your {tier} subscription is now active.
          Transaction ID: {transactionId}
          Trace: {traceid}
      </bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" />
        <zeebe:ioMapping>
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="=name" target="name" />
          <zeebe:input source="=tier" target="tier" />
          <zeebe:input source="=traceid" target="traceid" />
          <zeebe:input source="=paymentAmount" target="paymentAmount" />
          <zeebe:input source="=transactionId" target="transactionId" />
          <zeebe:input source="&quot;PaymentReceivedEvent&quot;" target="notificationType" />
          <zeebe:output source="=notificationSent" target="notificationSent" />
          <zeebe:output source="=notificationId" target="notificationId" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="eventType" value="PaymentReceivedEvent" />
          <zeebe:header key="emailSubject" value="Payment Confirmed - Welcome to WorldPulse!" />
          <zeebe:header key="kafkaTopic" value="worldpulse" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PaymentSuccess</bpmn:incoming>
      <bpmn:outgoing>Flow_to_ActivateAccount</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- SERVICE TASK: Send Payment Failed Notification -->
    <bpmn:serviceTask id="Task_NotifyPaymentFailed" name="Send Payment Failed Notification">
      <bpmn:documentation>
        Sends payment failure notification to user.
        
        Input: email, name, tier, traceid, paymentAmount
        Output: notificationSent (boolean), notificationId
        
        Email Template:
        Subject: Payment Failed - WorldPulse Signup
        Body:
          Dear {name},
          We could not process payment for {tier} tier.
          Amount attempted: CHF {amount}
          Please try again or contact support@worldpulse.com
          Trace: {traceid}
      </bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" />
        <zeebe:ioMapping>
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="=name" target="name" />
          <zeebe:input source="=tier" target="tier" />
          <zeebe:input source="=traceid" target="traceid" />
          <zeebe:input source="=paymentAmount" target="paymentAmount" />
          <zeebe:input source="&quot;PaymentFailedEvent&quot;" target="notificationType" />
          <zeebe:output source="=notificationSent" target="notificationSent" />
          <zeebe:output source="=notificationId" target="notificationId" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="eventType" value="PaymentFailedEvent" />
          <zeebe:header key="emailSubject" value="Payment Failed - WorldPulse Signup" />
          <zeebe:header key="kafkaTopic" value="worldpulse" />
          <zeebe:header key="retryAllowed" value="true" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_CancelSignup</bpmn:incoming>
      <bpmn:outgoing>Flow_to_EndFailed</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- SERVICE TASK: Send Welcome Notification (Free Tier) -->
    <bpmn:serviceTask id="Task_NotifyFreeTier" name="Send Welcome Notification">
      <bpmn:documentation>
        Sends welcome notification to FREE tier users.
        
        Input: email, name, tier, traceid
        Output: notificationSent (boolean), notificationId
        
        Email Template:
        Subject: Welcome to WorldPulse FREE!
        Body:
          Dear {name},
          Thank you for joining WorldPulse.
          Your FREE account is now active.
          Explore our platform and upgrade anytime!
          Trace: {traceid}
      </bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" />
        <zeebe:ioMapping>
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="=name" target="name" />
          <zeebe:input source="=tier" target="tier" />
          <zeebe:input source="=traceid" target="traceid" />
          <zeebe:input source="&quot;SignupRequestedEvent&quot;" target="notificationType" />
          <zeebe:output source="=notificationSent" target="notificationSent" />
          <zeebe:output source="=notificationId" target="notificationId" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="eventType" value="SignupRequestedEvent" />
          <zeebe:header key="emailSubject" value="Welcome to WorldPulse FREE!" />
          <zeebe:header key="tierType" value="FREE" />
          <zeebe:header key="kafkaTopic" value="worldpulse" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_FreeTier</bpmn:incoming>
      <bpmn:outgoing>Flow_to_ActivateAccountFree</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- SERVICE TASK: Activate User Account -->
    <bpmn:serviceTask id="Task_ActivateAccount" name="Activate User Account">
      <bpmn:documentation>
        Activates user account in the system.
        
        Input: userId, email, name, tier, traceid
        Output: accountActive (boolean), activatedAt (timestamp), apiToken
        
        Business Logic:
        - Create user record in database with userId
        - Set account status to ACTIVE
        - Grant permissions based on tier (FREE/PRO/ENTERPRISE)
        - Generate API access token for programmatic access
        - Set account activation timestamp
        - Create default user preferences
      </bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="activate-account" />
        <zeebe:ioMapping>
          <zeebe:input source="=userId" target="userId" />
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="=name" target="name" />
          <zeebe:input source="=tier" target="tier" />
          <zeebe:input source="=traceid" target="traceid" />
          <zeebe:output source="=accountActive" target="accountActive" />
          <zeebe:output source="=activatedAt" target="activatedAt" />
          <zeebe:output source="=apiToken" target="apiToken" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="database" value="worldpulse-users" />
          <zeebe:header key="accountStatus" value="ACTIVE" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_ActivateAccount</bpmn:incoming>
      <bpmn:incoming>Flow_to_ActivateAccountFree</bpmn:incoming>
      <bpmn:outgoing>Flow_to_EndSuccess</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- END EVENT: Success -->
    <bpmn:endEvent id="EndEvent_SignupSuccess" name="Signup Completed Successfully">
      <bpmn:documentation>
        Process ends successfully.
        User account is now ACTIVE and fully functional.
        User can login and access WorldPulse features based on their tier.
      </bpmn:documentation>
      <bpmn:incoming>Flow_to_EndSuccess</bpmn:incoming>
    </bpmn:endEvent>
    
    <!-- END EVENT: Payment Failed -->
    <bpmn:endEvent id="EndEvent_PaymentFailed" name="Signup Failed (Payment)">
      <bpmn:documentation>
        Process ends due to payment failure.
        User account is NOT created.
        User has been notified and can retry signup or contact support.
      </bpmn:documentation>
      <bpmn:incoming>Flow_to_EndFailed</bpmn:incoming>
    </bpmn:endEvent>
    
    <!-- USER TASK for Retry Decision -->
    <bpmn:userTask id="Task_RetryDecision" name="Decide: Retry Payment?">
      <bpmn:documentation>
        Manual decision point: User or support decides whether to retry payment.
        
        Options:
        - Retry Payment: Go back to payment processing
        - Cancel Signup: End process with failure
      </bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="retryPaymentForm" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PaymentFailed</bpmn:incoming>
      <bpmn:outgoing>Flow_to_RetryGateway</bpmn:outgoing>
    </bpmn:userTask>
    
    <!-- EXCLUSIVE GATEWAY for Retry Decision -->
    <bpmn:exclusiveGateway id="Gateway_RetryDecision" name="Retry?">
      <bpmn:documentation>
        Routes based on user's retry decision.
      </bpmn:documentation>
      <bpmn:incoming>Flow_to_RetryGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_RetryPayment</bpmn:outgoing>
      <bpmn:outgoing>Flow_CancelSignup</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <!-- END EVENT for Technical Errors -->
    <bpmn:endEvent id="EndEvent_TechnicalError" name="Technical Error">
      <bpmn:documentation>
        Process ends due to technical error (timeout, system failure, etc).
      </bpmn:documentation>
      <bpmn:incoming>Flow_PaymentTimeout_to_Error</bpmn:incoming>
      <bpmn:incoming>Flow_PaymentError_to_Error</bpmn:incoming>
      <bpmn:errorEventDefinition errorRef="Error_PaymentProcessing" />
    </bpmn:endEvent>
    
    <!-- SERVICE TASK for Error Notification -->
    <bpmn:serviceTask id="Task_NotifyError" name="Send Error Notification">
      <bpmn:documentation>
        Sends technical error notification to user and admins.
      </bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-notification" />
        <zeebe:ioMapping>
          <zeebe:input source="=email" target="email" />
          <zeebe:input source="=name" target="name" />
          <zeebe:input source="=tier" target="tier" />
          <zeebe:input source="=traceid" target="traceid" />
          <zeebe:input source="&quot;TechnicalError&quot;" target="notificationType" />
          <zeebe:output source="=notificationSent" target="notificationSent" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PaymentError_to_Notification</bpmn:incoming>
      <bpmn:outgoing>Flow_PaymentError_to_Error</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- SEQUENCE FLOWS -->
    <bpmn:sequenceFlow id="Flow_to_ValidateSignup" sourceRef="StartEvent_SignupRequest" targetRef="Task_ValidateSignup" />
    <bpmn:sequenceFlow id="Flow_to_InitialNotification" sourceRef="Task_ValidateSignup" targetRef="Task_SendInitialNotification" />
    <bpmn:sequenceFlow id="Flow_to_CheckTier" sourceRef="Task_SendInitialNotification" targetRef="Gateway_CheckTier" />
    <bpmn:sequenceFlow id="Flow_PaymentRequired" name="PRO or ENTERPRISE" sourceRef="Gateway_CheckTier" targetRef="Task_ProcessPayment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= tier = "PRO" or tier = "ENTERPRISE"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_FreeTier" name="FREE" sourceRef="Gateway_CheckTier" targetRef="Task_NotifyFreeTier">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= tier = "FREE"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_to_PaymentGateway" sourceRef="Task_ProcessPayment" targetRef="Gateway_PaymentResult" />
    <bpmn:sequenceFlow id="Flow_PaymentSuccess" name="Yes" sourceRef="Gateway_PaymentResult" targetRef="Task_NotifyPaymentSuccess">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= paymentSuccess = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_PaymentFailed" name="No" sourceRef="Gateway_PaymentResult" targetRef="Task_RetryDecision">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= paymentSuccess = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_to_RetryGateway" sourceRef="Task_RetryDecision" targetRef="Gateway_RetryDecision" />
    <bpmn:sequenceFlow id="Flow_RetryPayment" name="Yes" sourceRef="Gateway_RetryDecision" targetRef="Task_ProcessPayment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= retryPayment = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_CancelSignup" name="No" sourceRef="Gateway_RetryDecision" targetRef="Task_NotifyPaymentFailed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">= retryPayment = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_to_ActivateAccount" sourceRef="Task_NotifyPaymentSuccess" targetRef="Task_ActivateAccount" />
    <bpmn:sequenceFlow id="Flow_to_ActivateAccountFree" sourceRef="Task_NotifyFreeTier" targetRef="Task_ActivateAccount" />
    <bpmn:sequenceFlow id="Flow_to_EndSuccess" sourceRef="Task_ActivateAccount" targetRef="EndEvent_SignupSuccess" />
    <bpmn:sequenceFlow id="Flow_to_EndFailed" sourceRef="Task_NotifyPaymentFailed" targetRef="EndEvent_PaymentFailed" />
    <bpmn:sequenceFlow id="Flow_PaymentTimeout_to_Error" sourceRef="BoundaryEvent_PaymentTimeout" targetRef="EndEvent_TechnicalError" />
    <bpmn:sequenceFlow id="Flow_PaymentError_to_Notification" sourceRef="BoundaryEvent_PaymentError" targetRef="Task_NotifyError" />
    <bpmn:sequenceFlow id="Flow_PaymentError_to_Error" sourceRef="Task_NotifyError" targetRef="EndEvent_TechnicalError" />
    
  </bpmn:process>
  
  <!-- DIAGRAM LAYOUT -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="signup-payment-process">
      
      <!-- Row 1: Start → Validate → Initial Notification → Gateway -->
      <bpmndi:BPMNShape id="StartEvent_SignupRequest_di" bpmnElement="StartEvent_SignupRequest">
        <dc:Bounds x="152" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="136" y="265" width="69" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="Task_ValidateSignup_di" bpmnElement="Task_ValidateSignup">
        <dc:Bounds x="250" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="Task_SendInitialNotification_di" bpmnElement="Task_SendInitialNotification">
        <dc:Bounds x="410" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="Gateway_CheckTier_di" bpmnElement="Gateway_CheckTier" isMarkerVisible="true">
        <dc:Bounds x="575" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="573" y="185" width="54" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- Row 2 (TOP PATH): FREE Tier → Welcome → Activate -->
      <bpmndi:BPMNShape id="Task_NotifyFreeTier_di" bpmnElement="Task_NotifyFreeTier">
        <dc:Bounds x="700" y="80" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      
      <!-- Row 3 (MIDDLE PATH): Payment → Success → Activate -->
      <bpmndi:BPMNShape id="Task_ProcessPayment_di" bpmnElement="Task_ProcessPayment">
        <dc:Bounds x="700" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BoundaryEvent_PaymentTimeout_di" bpmnElement="BoundaryEvent_PaymentTimeout">
        <dc:Bounds x="712" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="640" y="295" width="62" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="BoundaryEvent_PaymentError_di" bpmnElement="BoundaryEvent_PaymentError">
        <dc:Bounds x="762" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="810" y="275" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="Gateway_PaymentResult_di" bpmnElement="Gateway_PaymentResult" isMarkerVisible="true">
        <dc:Bounds x="865" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="859" y="185" width="63" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="Task_NotifyPaymentSuccess_di" bpmnElement="Task_NotifyPaymentSuccess">
        <dc:Bounds x="980" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="Task_ActivateAccount_di" bpmnElement="Task_ActivateAccount">
        <dc:Bounds x="1150" y="200" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="EndEvent_SignupSuccess_di" bpmnElement="EndEvent_SignupSuccess">
        <dc:Bounds x="1322" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1299" y="265" width="83" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- Row 4 (BOTTOM PATH): Payment Failed → Retry Decision → Gateway -->
      <bpmndi:BPMNShape id="Task_RetryDecision_di" bpmnElement="Task_RetryDecision">
        <dc:Bounds x="980" y="350" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="Gateway_RetryDecision_di" bpmnElement="Gateway_RetryDecision" isMarkerVisible="true">
        <dc:Bounds x="865" y="365" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="874" y="422" width="32" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="Task_NotifyPaymentFailed_di" bpmnElement="Task_NotifyPaymentFailed">
        <dc:Bounds x="700" y="470" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="EndEvent_PaymentFailed_di" bpmnElement="EndEvent_PaymentFailed">
        <dc:Bounds x="562" y="492" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="548" y="535" width="65" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- Row 5 (ERROR PATH): Error Notification → Technical Error End -->
      <bpmndi:BPMNShape id="Task_NotifyError_di" bpmnElement="Task_NotifyError">
        <dc:Bounds x="700" y="590" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="EndEvent_TechnicalError_di" bpmnElement="EndEvent_TechnicalError">
        <dc:Bounds x="562" y="612" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="541" y="655" width="78" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- EDGES / SEQUENCE FLOWS -->
      
      <!-- Main flow: Start → Validate → Initial Notification → Gateway -->
      <bpmndi:BPMNEdge id="Flow_to_ValidateSignup_di" bpmnElement="Flow_to_ValidateSignup">
        <di:waypoint x="188" y="240" />
        <di:waypoint x="250" y="240" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_to_InitialNotification_di" bpmnElement="Flow_to_InitialNotification">
        <di:waypoint x="350" y="240" />
        <di:waypoint x="410" y="240" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_to_CheckTier_di" bpmnElement="Flow_to_CheckTier">
        <di:waypoint x="510" y="240" />
        <di:waypoint x="575" y="240" />
      </bpmndi:BPMNEdge>
      
      <!-- FREE Tier Path (Top) -->
      <bpmndi:BPMNEdge id="Flow_FreeTier_di" bpmnElement="Flow_FreeTier">
        <di:waypoint x="600" y="215" />
        <di:waypoint x="600" y="120" />
        <di:waypoint x="700" y="120" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="603" y="165" width="29" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_to_ActivateAccountFree_di" bpmnElement="Flow_to_ActivateAccountFree">
        <di:waypoint x="800" y="120" />
        <di:waypoint x="1200" y="120" />
        <di:waypoint x="1200" y="200" />
      </bpmndi:BPMNEdge>
      
      <!-- Payment Path (Middle) -->
      <bpmndi:BPMNEdge id="Flow_PaymentRequired_di" bpmnElement="Flow_PaymentRequired">
        <di:waypoint x="625" y="240" />
        <di:waypoint x="700" y="240" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="620" y="222" width="67" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_to_PaymentGateway_di" bpmnElement="Flow_to_PaymentGateway">
        <di:waypoint x="800" y="240" />
        <di:waypoint x="865" y="240" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_PaymentSuccess_di" bpmnElement="Flow_PaymentSuccess">
        <di:waypoint x="915" y="240" />
        <di:waypoint x="980" y="240" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="939" y="222" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_to_ActivateAccount_di" bpmnElement="Flow_to_ActivateAccount">
        <di:waypoint x="1080" y="240" />
        <di:waypoint x="1150" y="240" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_to_EndSuccess_di" bpmnElement="Flow_to_EndSuccess">
        <di:waypoint x="1250" y="240" />
        <di:waypoint x="1322" y="240" />
      </bpmndi:BPMNEdge>
      
      <!-- Payment Failed → Retry Path (Bottom) -->
      <bpmndi:BPMNEdge id="Flow_PaymentFailed_di" bpmnElement="Flow_PaymentFailed">
        <di:waypoint x="890" y="265" />
        <di:waypoint x="890" y="390" />
        <di:waypoint x="980" y="390" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="898" y="325" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_to_RetryGateway_di" bpmnElement="Flow_to_RetryGateway">
        <di:waypoint x="980" y="390" />
        <di:waypoint x="915" y="390" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_RetryPayment_di" bpmnElement="Flow_RetryPayment">
        <di:waypoint x="865" y="390" />
        <di:waypoint x="750" y="390" />
        <di:waypoint x="750" y="280" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="799" y="372" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_CancelSignup_di" bpmnElement="Flow_CancelSignup">
        <di:waypoint x="890" y="415" />
        <di:waypoint x="890" y="510" />
        <di:waypoint x="800" y="510" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="898" y="460" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_to_EndFailed_di" bpmnElement="Flow_to_EndFailed">
        <di:waypoint x="700" y="510" />
        <di:waypoint x="598" y="510" />
      </bpmndi:BPMNEdge>
      
      <!-- Error Handling Path -->
      <bpmndi:BPMNEdge id="Flow_PaymentTimeout_to_Error_di" bpmnElement="Flow_PaymentTimeout_to_Error">
        <di:waypoint x="730" y="298" />
        <di:waypoint x="730" y="630" />
        <di:waypoint x="598" y="630" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_PaymentError_to_Notification_di" bpmnElement="Flow_PaymentError_to_Notification">
        <di:waypoint x="780" y="298" />
        <di:waypoint x="780" y="630" />
        <di:waypoint x="800" y="630" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Flow_PaymentError_to_Error_di" bpmnElement="Flow_PaymentError_to_Error">
        <di:waypoint x="700" y="630" />
        <di:waypoint x="598" y="630" />
      </bpmndi:BPMNEdge>
      
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>